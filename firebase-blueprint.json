{
  "entities": {
    "ShowcaseItem": {
      "title": "Showcase Item",
      "description": "A cultural artifact, food, or activity displayed in the heritage feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["food", "wares", "activities", "history", "stories", "dances"] },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "image"]
    },
    "Admin": {
      "title": "Admin User",
      "description": "A user with administrative privileges in the digital archive.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin"] },
        "displayName": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Announcement": {
      "title": "Dispatch",
      "description": "System-wide archival updates and cultural broadcasts.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "achievement"] },
        "date": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "content", "type"]
    },
    "Extension": {
      "title": "Archival Plugin",
      "description": "Modular extensions for the heritage system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "apiKeyRequired": { "type": "boolean" },
        "config": { "type": "object" }
      },
      "required": ["name", "status"]
    },
    "Integration": {
      "title": "External API",
      "description": "Connections to external cultural datasets or AI services.",
      "type": "object",
      "properties": {
        "providerName": { "type": "string" },
        "endpoint": { "type": "string" },
        "lastSynced": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["connected", "disconnected"] }
      },
      "required": ["providerName", "endpoint", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored preferences and learning progress for each user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "level": { "type": "integer", "default": 1 },
        "xp": { "type": "integer", "default": 0 },
        "ageMode": { "type": "string", "enum": ["adult", "child"], "default": "adult" },
        "persona": { "type": "string", "enum": ["professional", "friendly", "bestie", "colleague"], "default": "friendly" },
        "faceVerified": { "type": "boolean", "default": false },
        "learningLog": { "type": "array" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/showcase/{itemId}": {
      "schema": "ShowcaseItem",
      "description": "Public collection of cultural showcase items."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Internal collection of admin users."
    },
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles and settings."
    },
    "/announcements/{annId}": {
      "schema": "Announcement",
      "description": "Global archival dispatches."
    },
    "/extensions/{extId}": {
      "schema": "Extension",
      "description": "System plugins and modules."
    },
    "/integrations/{intId}": {
      "schema": "Integration",
      "description": "External API service configurations."
    }
  }
}
