rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBALS & HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "donmckenz20@gmail.com"
      );
    }

    function isOwner() {
      return isAdmin() && (
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'owner') ||
        request.auth.token.email == "donmckenz20@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // ADMINS COLLECTION
    // -------------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isAdmin();
      
      allow create: if (isOwner() || (isSignedIn() && !exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && request.auth.token.email == "donmckenz20@gmail.com")) && 
        isValidId(adminId) &&
        incoming().uid == adminId &&
        incoming().role in ['owner', 'admin'] &&
        incoming().email is string &&
        incoming().email.size() < 256;
        
      allow update: if isOwner() && 
        incoming().uid == adminId &&
        incoming().role in ['owner', 'admin'] &&
        incoming().email == existing().email; // Email is immutable
        
      allow delete: if isOwner() && adminId != request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // SHOWCASE / HERITAGE POSTS
    // -------------------------------------------------------------------------
    match /showcase/{itemId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidId(itemId);
    }

    // -------------------------------------------------------------------------
    // ANNOUNCEMENTS / DISPATCHES
    // -------------------------------------------------------------------------
    match /announcements/{annId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidId(annId);
    }

    // -------------------------------------------------------------------------
    // USER PROFILES
    // -------------------------------------------------------------------------
    match /profiles/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId &&
        incoming().uid == userId &&
        incoming().xp == 0 &&
        incoming().level == 1; // Prevent self-leveling on create
      
      allow update: if isSignedIn() && request.auth.uid == userId &&
        incoming().uid == userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'displayName', 'photoURL', 'persona', 'ageMode', 'faceVerified', 'achievements']);
    }

    // -------------------------------------------------------------------------
    // SCANS (HERITAGE RADAR)
    // -------------------------------------------------------------------------
    match /scans/{scanId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && 
        incoming().uid == request.auth.uid &&
        incoming().analysis is string &&
        incoming().analysis.size() < 10000; // Size limit
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // EXTENSIONS & INTEGRATIONS
    // -------------------------------------------------------------------------
    match /extensions/{extId} {
       allow read: if isAdmin();
       allow write: if isAdmin() && isValidId(extId);
    }

    match /integrations/{intId} {
       allow read: if isAdmin();
       allow write: if isAdmin() && isValidId(intId);
    }

    // Default Deny - Keep at bottom
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
