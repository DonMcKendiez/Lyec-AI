rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Security Pillar - MUST BE FIRST
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // HELPERS & PRIMITIVES
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "donmckenz20@gmail.com"
      );
    }

    function isOwner() {
      // Identity Roles (Founder/Owner)
      return isAdmin() && (
        request.auth.token.email == "donmckenz20@gmail.com" ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'owner')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // 1. SHOWCASE / HERITAGE POSTS
    // -------------------------------------------------------------------------
    function isValidShowcase(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.category in ['food', 'wares', 'activities', 'history', 'stories', 'dances'] &&
             data.image is string && data.image.size() <= 2048;
    }

    match /showcase/{itemId} {
      allow get: if true; // Publicly accessible archival item
      allow list: if resource.data.category is string; // Enforce secure query boundaries - item must have a category
      
      allow create: if isAdmin() && isValidId(itemId) && 
        isValidShowcase(incoming()) &&
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time;
        
      allow update: if isAdmin() && 
        isValidShowcase(incoming()) &&
        incoming().updatedAt == request.time &&
        incoming().id == existing().id &&
        incoming().createdAt == existing().createdAt;
        
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // TEST CONNECTION
    // -------------------------------------------------------------------------
    match /test/connection {
      allow get: if true;
    }

    // -------------------------------------------------------------------------
    // 2. ADMINS COLLECTION
    // -------------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isAdmin();
      
      allow create: if (isOwner() || (isSignedIn() && request.auth.token.email == "donmckenz20@gmail.com")) && 
        isValidId(adminId) &&
        incoming().uid == adminId &&
        incoming().role in ['owner', 'admin'] &&
        incoming().email is string &&
        incoming().email.size() < 256;
        
      allow update: if isOwner() && 
        incoming().uid == adminId &&
        incoming().role in ['owner', 'admin'] &&
        incoming().email == existing().email;
        
      allow delete: if isOwner() && adminId != request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // 3. ANNOUNCEMENTS / DISPATCHES
    // -------------------------------------------------------------------------
    match /announcements/{annId} {
      allow get: if true;
      allow list: if resource.data.title is string;
      allow write: if isAdmin() && isValidId(annId);
    }

    // -------------------------------------------------------------------------
    // 4. USER PROFILES
    // -------------------------------------------------------------------------
    match /profiles/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId &&
        isValidId(userId) &&
        incoming().uid == userId &&
        incoming().xp == 0 &&
        incoming().level == 1;
      
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId &&
        incoming().uid == userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'displayName', 'photoURL', 'persona', 'ageMode', 'faceVerified', 'achievements', 'learningLog', 'targetLanguage']));
    }

    // -------------------------------------------------------------------------
    // 5. SCANS (HERITAGE RADAR)
    // -------------------------------------------------------------------------
    match /scans/{scanId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && 
        incoming().uid == request.auth.uid &&
        incoming().analysis is string &&
        incoming().analysis.size() < 10000;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // 6. EXTENSIONS & INTEGRATIONS (SYSTEM LEVEL)
    // -------------------------------------------------------------------------
    match /extensions/{extId} {
       allow read: if isAdmin();
       allow write: if isAdmin() && isValidId(extId);
    }

    match /integrations/{intId} {
       allow read: if isAdmin();
       allow write: if isAdmin() && isValidId(intId);
    }
  }
}

